{
  "version": 2,
  "functions": {
    "api/parse-lv.js": {
      "maxDuration": 60
    },
    "api/ares.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
